{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chrome 环境工作台",
  "version": "0.1.2",
  "identifier": "local.chrome.manage",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Chrome 环境工作台",
        "width": 1160,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
